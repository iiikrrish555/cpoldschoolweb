modules = ["web", "python-3.12", "nodejs-20", "python3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "zlib"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 serve.py"
waitForPort = 5000

[deployment]
deploymentTarget = "static"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "Run:app"]
publicDir = "dist"
build = ["bash", "-c", "rm -rf dist && mkdir -p dist && cp index.html help.html 404.html dist/ && cp -r static dist/static"]
